# =========================
# 本地目录配置
# =========================

# 如果不配置，默认使用项目内目录
DATA_DIR=data
SOURCE_PDF_DIR=data/source_pdf
ARTIFACTS_DIR=artifacts
PARSED_DIR=artifacts/parsed
CHUNKS_DIR=artifacts/chunks
MANIFESTS_DIR=artifacts/manifests
INDEXES_DIR=indexes
RETRIEVAL_INDEX_DIR=indexes/retrieval_cache/bge_base_zh_v1_5


# =========================
# LLM 调用配置
# =========================

# 当前默认使用 OpenAI 兼容接口调用 DashScope
LLM_PROVIDER=openai_compatible

# 可选:
# - auto
# - zh_generic
# - qwen
LLM_PROMPT_FAMILY=auto

# DashScope OpenAI-compatible 配置
DASHSCOPE_API_KEY=your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus


# =========================
# 检索与问答配置
# =========================

# 问答时默认取回的候选数
QA_TOP_K=6


# =========================
# 混合召回配置
# =========================

# 可选: rrf, weighted_rank
FUSION_MODE=rrf

# 仅在 FUSION_MODE=rrf 时生效
FUSION_RRF_K=60

# 不同召回通道的权重
FUSION_BM25_WEIGHT=1.0
FUSION_VECTOR_WEIGHT=1.0


# =========================
# Reranker 配置
# =========================

# 可选:
# - noop
# - local_transformers
RERANKER_PROVIDER=noop

# 仅在启用本地 reranker 时生效
RERANKER_TOP_N=20
RERANKER_BATCH_SIZE=8


# =========================
# 调试配置
# =========================

APP_DEBUG=false


# =========================
# 说明
# =========================

# 本地模型目录，按需填写；未配置时：
# - Embedding 会回退到无模型模式
# - Reranker 若 provider=noop 则不会加载本地模型
LOCAL_EMBEDDING_MODEL_DIR=
LOCAL_RERANKER_MODEL_DIR=
